{
  "bot": {
    "name": "Server Creator Pro",
    "version": "2.0.0",
    "description": "Bot avançado para criação automática de servidores Discord",
    "prefix": "/",
    "default_language": "pt-BR"
  },
  "limits": {
    "max_channels_per_guild": 500,
    "max_roles_per_guild": 250,
    "max_categories_per_guild": 50,
    "creation_cooldown": 30,
    "max_servers_per_hour": 5,
    "max_backups_per_server": 10
  },
  "themes": {
    "count": 30,
    "custom_enabled": true,
    "ai_generation": true
  },
  "features": {
    "auto_backup": true,
    "auto_logs": true,
    "anti_error": true,
    "cooldown_system": true,
    "template_system": true,
    "save_system": true
  },
  "colors": {
    "primary": 0x5865F2,
    "success": 0x57F287,
    "warning": 0xFEE75C,
    "error": 0xED4245,
    "info": 0xEB459E
  },
  "emojis": {
    "success": "✅",
    "error": "❌",
    "warning": "⚠️",
    "loading": "⏳",
    "info": "ℹ️",
    "star": "⭐",
    "rocket": "🚀",
    "gear": "⚙️",
    "shield": "🛡️",
    "crown": "👑",
    "fire": "🔥",
    "sparkles": "✨",
    "magic": "🪄",
    "palette": "🎨",
    "brain": "🧠",
    "bulb": "💡"
  }
}
